{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "subject.schema.json",
  "title": "Synapse Core subject record v0.1",
  "allOf": [
    { "$ref": "record-envelope.schema.json" },
    {
      "properties": {
        "record_type": { "const": "subject" },
        "payload": {
          "type": "object",
          "required": ["subject_kind", "label"],
          "properties": {
            "subject_kind": {
              "enum": ["physical", "digital", "conceptual", "hybrid"]
            },
            "label": { "type": "string", "minLength": 1, "maxLength": 500 },
            "description": { "type": "string", "maxLength": 5000 },
            "relation_refs": {
              "type": "array",
              "items": { "$ref": "common.schema.json#/$defs/RecordOid" },
              "uniqueItems": true,
              "x-synapse-order": "set"
            },
            "spatial_frame_refs": {
              "type": "array",
              "items": { "$ref": "common.schema.json#/$defs/EntityId" },
              "uniqueItems": true,
              "x-synapse-order": "set"
            }
          },
          "additionalProperties": false
        }
      }
    }
  ]
}
