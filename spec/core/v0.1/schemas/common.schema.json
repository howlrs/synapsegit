{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "common.schema.json",
  "title": "Synapse Core v0.1 common definitions",
  "$defs": {
    "SchemaVersion": {
      "const": "0.1.0",
      "x-synapse-string": "identifier-nfc"
    },
    "EntityId": {
      "type": "string",
      "pattern": "^urn:uuid:[0-9a-f]{8}-[0-9a-f]{4}-4[0-9a-f]{3}-[89ab][0-9a-f]{3}-[0-9a-f]{12}$",
      "x-synapse-string": "identifier-nfc"
    },
    "Oid": {
      "type": "string",
      "pattern": "^(blob|record|tree|commit):sg-oid-v1:sha256:[0-9a-f]{64}$",
      "x-synapse-string": "identifier-nfc"
    },
    "BlobOid": {
      "type": "string",
      "pattern": "^blob:sg-oid-v1:sha256:[0-9a-f]{64}$",
      "x-synapse-string": "identifier-nfc"
    },
    "RecordOid": {
      "type": "string",
      "pattern": "^record:sg-oid-v1:sha256:[0-9a-f]{64}$",
      "x-synapse-string": "identifier-nfc"
    },
    "TreeOid": {
      "type": "string",
      "pattern": "^tree:sg-oid-v1:sha256:[0-9a-f]{64}$",
      "x-synapse-string": "identifier-nfc"
    },
    "CommitOid": {
      "type": "string",
      "pattern": "^commit:sg-oid-v1:sha256:[0-9a-f]{64}$",
      "x-synapse-string": "identifier-nfc"
    },
    "Timestamp": {
      "type": "string",
      "format": "date-time",
      "pattern": "^[0-9]{4}-(0[1-9]|1[0-2])-([0-2][0-9]|3[01])T([01][0-9]|2[0-3]):[0-5][0-9]:[0-5][0-9]\\.[0-9]{9}Z$",
      "x-synapse-string": "canonical-timestamp"
    },
    "ValidTime": {
      "oneOf": [
        {
          "type": "object",
          "required": ["kind", "at"],
          "properties": {
            "kind": { "const": "instant" },
            "at": { "$ref": "#/$defs/Timestamp" },
            "precision": { "$ref": "#/$defs/TemporalPrecision" }
          },
          "additionalProperties": false
        },
        {
          "type": "object",
          "required": ["kind"],
          "properties": {
            "kind": { "const": "interval" },
            "from": { "$ref": "#/$defs/Timestamp" },
            "to": { "$ref": "#/$defs/Timestamp" },
            "precision": { "$ref": "#/$defs/TemporalPrecision" }
          },
          "anyOf": [
            { "required": ["from"] },
            { "required": ["to"] }
          ],
          "additionalProperties": false
        },
        {
          "type": "object",
          "required": ["kind", "reason"],
          "properties": {
            "kind": { "const": "unknown" },
            "reason": { "type": "string", "minLength": 1, "maxLength": 500 }
          },
          "additionalProperties": false
        }
      ]
    },
    "TemporalPrecision": {
      "oneOf": [
        {
          "type": "object",
          "required": ["kind", "value"],
          "properties": {
            "kind": { "enum": ["resolution", "uncertainty"] },
            "value": { "$ref": "#/$defs/ScaledInteger" }
          },
          "additionalProperties": false
        },
        {
          "type": "object",
          "required": ["kind"],
          "properties": {
            "kind": { "const": "unknown" }
          },
          "additionalProperties": false
        }
      ]
    },
    "ScaledInteger": {
      "type": "object",
      "required": ["mantissa", "scale", "unit"],
      "properties": {
        "mantissa": {
          "type": "string",
          "pattern": "^(0|-?(?:[1-9]|[1-9][0-9]*[1-9]))$",
          "maxLength": 257
        },
        "scale": {
          "type": "integer",
          "minimum": -24,
          "maximum": 24
        },
        "unit": { "$ref": "#/$defs/Unit" }
      },
      "allOf": [
        {
          "if": {
            "properties": { "mantissa": { "const": "0" } },
            "required": ["mantissa"]
          },
          "then": {
            "properties": { "scale": { "const": 0 } }
          }
        }
      ],
      "additionalProperties": false
    },
    "Unit": {
      "enum": [
        "unitless",
        "ratio",
        "percent",
        "count",
        "byte",
        "px",
        "mm",
        "m",
        "ms",
        "s",
        "deg",
        "rad",
        "kelvin",
        "celsius",
        "delta_e"
      ]
    },
    "Confidence": {
      "oneOf": [
        {
          "type": "object",
          "required": ["kind", "value", "calibrated"],
          "properties": {
            "kind": { "const": "probability" },
            "value": { "$ref": "#/$defs/ScaledInteger" },
            "calibrated": { "type": "boolean" },
            "calibration_ref": { "$ref": "#/$defs/RecordOid" }
          },
          "additionalProperties": false
        },
        {
          "type": "object",
          "required": ["kind", "value", "scale_id"],
          "properties": {
            "kind": { "const": "quality_score" },
            "value": { "$ref": "#/$defs/ScaledInteger" },
            "scale_id": { "type": "string", "minLength": 1, "maxLength": 200 }
          },
          "additionalProperties": false
        },
        {
          "type": "object",
          "required": ["kind", "lower", "upper"],
          "properties": {
            "kind": { "const": "interval" },
            "lower": { "$ref": "#/$defs/ScaledInteger" },
            "upper": { "$ref": "#/$defs/ScaledInteger" }
          },
          "additionalProperties": false
        },
        {
          "type": "object",
          "required": ["kind", "value", "scale_id"],
          "properties": {
            "kind": { "const": "ordinal" },
            "value": { "type": "string", "minLength": 1, "maxLength": 100 },
            "scale_id": { "type": "string", "minLength": 1, "maxLength": 200 }
          },
          "additionalProperties": false
        }
      ]
    },
    "RoleOidRef": {
      "type": "object",
      "required": ["role", "oid"],
      "properties": {
        "role": { "$ref": "#/$defs/Role" },
        "oid": { "$ref": "#/$defs/Oid" }
      },
      "additionalProperties": false
    },
    "RoleBlobRef": {
      "type": "object",
      "required": ["role", "oid"],
      "properties": {
        "role": { "$ref": "#/$defs/Role" },
        "oid": { "$ref": "#/$defs/BlobOid" }
      },
      "additionalProperties": false
    },
    "RoleActorRef": {
      "type": "object",
      "required": ["role", "actor_ref"],
      "properties": {
        "role": { "$ref": "#/$defs/Role" },
        "actor_ref": { "$ref": "#/$defs/EntityId" }
      },
      "additionalProperties": false
    },
    "Role": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9._-]{0,99}$",
      "x-synapse-string": "identifier-nfc"
    },
    "RefName": {
      "type": "string",
      "pattern": "^(proposal|decision|release|observed|material-events)(/[a-z0-9][a-z0-9._:-]{0,127})+$",
      "maxLength": 500,
      "x-synapse-string": "identifier-nfc"
    },
    "Extensions": {
      "type": "object",
      "propertyNames": {
        "pattern": "^[a-z][a-z0-9-]*(\\.[a-z0-9-]+)+$"
      },
      "additionalProperties": true
    },
    "SpatialRegion": {
      "type": "object",
      "required": ["frame_ref", "representation"],
      "properties": {
        "frame_ref": { "$ref": "#/$defs/EntityId" },
        "representation": {
          "enum": ["whole", "bbox", "polygon", "mask", "element"]
        },
        "data_ref": { "$ref": "#/$defs/Oid" },
        "element_id": { "type": "string", "maxLength": 500 },
        "description": { "type": "string", "maxLength": 1000 }
      },
      "additionalProperties": false
    }
  }
}
