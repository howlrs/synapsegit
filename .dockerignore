# Keep credentials, local state, documentation, and unrelated tooling out of the
# build context. The Dockerfile only needs the locked Rust workspace and smoke
# assets listed below.
**
!Dockerfile
!Cargo.toml
!Cargo.lock
!crates/
!crates/**
!spec/
!spec/core/
!spec/core/v0.1/
!spec/core/v0.1/schemas/
!spec/core/v0.1/schemas/*.json
!deploy/
!deploy/gcp/
!deploy/gcp/smoke/
!deploy/gcp/smoke/**
